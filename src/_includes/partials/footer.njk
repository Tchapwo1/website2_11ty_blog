<footer class="bg-surface-container-low dark:bg-slate-950 py-16 px-8 mt-20 border-t border-outline-variant/10">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
    <div class="col-span-1 md:col-span-1">
      <div class="text-xl font-bold text-blue-950 dark:text-white font-headline mb-6">{{ site.name }}</div>
      <p class="text-slate-500 font-inter text-sm leading-relaxed mb-8">
        {{ site.description }}
      </p>
      <div class="flex gap-4">
        <a class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all" href="#">
          <span class="material-symbols-outlined text-xl">rss_feed</span>
        </a>
        <a class="w-10 h-10 rounded-full bg-surface-container-high flex items-center justify-center text-primary hover:bg-primary hover:text-white transition-all" href="#">
          <span class="material-symbols-outlined text-xl">alternate_email</span>
        </a>
      </div>
    </div>
    <div class="space-y-4">
      <h4 class="font-bold text-primary dark:text-blue-100 uppercase text-xs tracking-widest">Navigation</h4>
      <ul class="space-y-3 font-inter text-sm">
        {% for item in site.navigation %}
          <li><a class="text-slate-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" href="{{ item.url }}">{{ item.label }}</a></li>
        {% endfor %}
      </ul>
    </div>
    <div class="space-y-4">
      <h4 class="font-bold text-primary dark:text-blue-100 uppercase text-xs tracking-widest">Categories</h4>
      <ul class="space-y-3 font-inter text-sm">
        {% for category in site.categories %}
          <li><a class="text-slate-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" href="/categories/{{ category | slugify }}/">{{ category }}</a></li>
        {% endfor %}
      </ul>
    </div>
    <div class="space-y-4">
      <h4 class="font-bold text-primary dark:text-blue-100 uppercase text-xs tracking-widest">Legal</h4>
      <ul class="space-y-3 font-inter text-sm">
        <li><a class="text-slate-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" href="#">Privacy Policy</a></li>
        <li><a class="text-slate-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" href="#">Terms of Service</a></li>
        <li><a class="text-slate-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" href="#">Affiliate Disclosure</a></li>
        <li><a class="text-slate-500 hover:text-blue-600 dark:hover:text-blue-400 transition-colors" href="#">Contact Us</a></li>
      </ul>
    </div>
  </div>
  <div class="max-w-7xl mx-auto mt-16 pt-8 border-t border-outline-variant/10 text-center">
    <p class="text-slate-500 font-inter text-sm leading-relaxed">
      &copy; {{ "" | date("YYYY") }} {{ site.name }}. Curating the future for the solo founder.
    </p>
  </div>
</footer>
