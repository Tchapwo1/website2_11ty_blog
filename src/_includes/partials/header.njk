<nav class="fixed top-0 w-full z-50 bg-surface/80 dark:bg-slate-900/80 backdrop-blur-lg shadow-sm">
  <div class="max-w-7xl mx-auto flex justify-between items-center px-8 py-4">
    <div class="text-2xl font-bold tracking-tighter text-blue-950 dark:text-white font-headline">
      <a href="/">{{ site.name }}</a>
    </div>
    <div class="hidden md:flex items-center gap-8 font-manrope font-bold tracking-tight">
      {% for item in site.navigation %}
        <a class="{% if page.url == item.url %}text-blue-700 dark:text-blue-300 border-b-2 border-blue-700 dark:border-blue-300 pb-1{% else %}text-slate-600 dark:text-slate-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors{% endif %}" href="{{ item.url }}">{{ item.label }}</a>
      {% endfor %}
    </div>
    <div class="flex items-center gap-6">
      <button id="theme-toggle" class="material-symbols-outlined text-on-surface-variant hover:text-primary transition-colors">dark_mode</button>
      <div class="hidden lg:flex items-center bg-surface-container-high px-4 py-2 rounded-full relative group">
        <span class="material-symbols-outlined text-outline text-sm mr-2">search</span>
        <div id="search" class="min-w-[14rem] h-8"></div>
      </div>

    <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
    <script src="/pagefind/pagefind-ui.js"></script>
    <script>
        window.addEventListener('DOMContentLoaded', (event) => {
            new PagefindUI({ 
                element: "#search", 
                showSubResults: true,
                bundlePath: "/pagefind/",
                showImages: false
            });
        });
    </script>
      <button class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-6 py-2 rounded-full font-bold hover:scale-95 duration-150 transition-all shadow-md">
        Newsletter
      </button>
    </div>

    <script>
      const themeToggle = document.getElementById('theme-toggle');
      const themeIcon = themeToggle;

      // Initialize icon
      if (document.documentElement.classList.contains('dark')) {
        themeIcon.innerText = 'light_mode';
      }

      themeToggle.addEventListener('click', () => {
        if (document.documentElement.classList.contains('dark')) {
          document.documentElement.classList.remove('dark');
          localStorage.theme = 'light';
          themeIcon.innerText = 'dark_mode';
        } else {
          document.documentElement.classList.add('dark');
          localStorage.theme = 'dark';
          themeIcon.innerText = 'light_mode';
        }
      });
    </script>
  </div>
</nav>
