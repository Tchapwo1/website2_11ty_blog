<div class="bg-surface-container-low rounded-3xl p-8 md:p-12 mb-20 border border-outline-variant/10 shadow-sm overflow-hidden relative" id="calculator">
  <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full -mr-32 -mt-32 blur-3xl"></div>
  
  <div class="max-w-4xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 relative z-10">
    <div class="lg:col-span-7">
      <div class="inline-flex items-center gap-2 bg-on-tertiary-container/10 text-on-tertiary-container px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest mb-6 border border-on-tertiary-container/20">
        <span class="material-symbols-outlined text-xs">analytics</span>
        The AI ROI Engine
      </div>
      <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">Calculate Your <span class="text-primary italic">Solo Overhead</span></h2>
      <p class="text-on-surface-variant leading-relaxed mb-8 font-body">
        Estimate your monthly subscription stack. Running a solo business with AI usually costs <span class="font-bold text-on-surface">90% less</span> than hiring a single virtual assistant.
      </p>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {% for tool in tools %}
        <label title="{{ tool.description }}" class="group flex items-center justify-between p-4 bg-surface-container-lowest rounded-xl border border-outline-variant/5 cursor-pointer hover:border-primary/30 transition-all active:scale-95">
          <div class="flex items-center gap-4">
            <div class="w-10 h-10 rounded-lg bg-surface-container-high flex items-center justify-center text-on-surface-variant group-hover:bg-primary/10 group-hover:text-primary transition-colors">
              <span class="material-symbols-outlined text-xl">{{ tool.icon }}</span>
            </div>
            <div>
              <p class="text-sm font-bold leading-tight">{{ tool.name }}</p>
              <p class="text-[10px] text-on-surface-variant font-medium uppercase tracking-tighter">{{ tool.category }}</p>
            </div>
          </div>
          <div class="flex items-center gap-3">
             <span class="text-xs font-bold text-outline">${{ tool.cost }}</span>
             <input type="checkbox" data-cost="{{ tool.cost }}" class="w-5 h-5 rounded-md border-outline-variant text-primary focus:ring-primary/20 tool-checkbox shadow-sm" checked>
          </div>
        </label>
        {% endfor %}
      </div>
    </div>
    
    <div class="lg:col-span-5 flex flex-col justify-center">
      <div class="bg-primary/5 rounded-2xl p-8 border border-primary/10 text-center lg:text-left space-y-6">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-on-surface-variant mb-2">Total Monthly Spend</p>
          <div class="text-6xl md:text-7xl font-extrabold tracking-tighter text-primary flex items-baseline justify-center lg:justify-start">
            <span class="text-4xl mr-1">$</span>
            <span id="calc-total">0</span>
          </div>
        </div>
        
        <div class="space-y-4">
          <div class="p-4 bg-tertiary-fixed text-on-tertiary-fixed-variant rounded-xl flex items-center justify-between">
            <span class="text-xs font-bold uppercase tracking-widest">Efficiency Multiplier</span>
            <span id="calc-multiplier" class="text-lg font-bold">0x</span>
          </div>
          <div class="p-4 bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300 rounded-xl flex items-center justify-between">
            <span class="text-xs font-bold uppercase tracking-widest">Monthly Savings</span>
            <span id="calc-savings" class="text-lg font-bold">$0</span>
          </div>
          <p class="text-xs text-on-surface-variant font-medium italic">
            *Benchmarked against an entry-level Virtual Assistant ($1,200/mo).
          </p>
          <button class="w-full bg-primary text-on-primary py-4 rounded-xl font-bold shadow-lg hover:shadow-xl hover:translate-y-[-2px] transition-all">
            Unlock Full Optimization Plan
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const multiplierEl = document.getElementById('calc-multiplier');
    const savingsEl = document.getElementById('calc-savings');
    const VA_COST = 1200;
    
    function calculate() {
        let total = 0;
        checkboxes.forEach(cb => {
            if (cb.checked) {
                total += parseFloat(cb.dataset.cost);
            }
        });
        
        // Multiplier calculation
        const multiplier = total > 0 ? (VA_COST / total).toFixed(1) : 0;
        const savings = Math.max(0, VA_COST - total);
        
        // Update values
        multiplierEl.innerText = multiplier + 'x';
        savingsEl.innerText = '$' + savings.toLocaleString();
        
        // Simple counter animation for total
        const current = parseInt(totalEl.innerText);
        if (current !== total) {
           animateValue(totalEl, current, total, 400);
        }
    }
    
    function animateValue(obj, start, end, duration) {
        let startTimestamp = null;
        const step = (timestamp) => {
            if (!startTimestamp) startTimestamp = timestamp;
            const progress = Math.min((timestamp - startTimestamp) / duration, 1);
            obj.innerHTML = Math.floor(progress * (end - start) + start);
            if (progress < 1) {
                window.requestAnimationFrame(step);
            }
        };
        window.requestAnimationFrame(step);
    }
    
    checkboxes.forEach(cb => {
        cb.addEventListener('change', calculate);
    });
    
    // Initial calculation
    calculate();
});
</script>
