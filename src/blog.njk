---
layout: layouts/base.njk
title: Blog
---

<!-- Hero Section -->
<header class="max-w-7xl mx-auto px-8 mb-16 pt-12">
  <div class="max-w-3xl">
    <span class="text-xs font-bold tracking-[0.15em] uppercase text-primary mb-4 block">The Digital Curator</span>
    <h1 class="text-5xl md:text-6xl font-extrabold tracking-tighter text-on-surface mb-6 leading-[1.1]">AI Tools for Solo Entrepreneurs.</h1>
    <p class="text-xl text-on-surface-variant leading-relaxed font-body">Expertly curated insights and deep-dives into the artificial intelligence landscape, tailored specifically for the independent builder.</p>
  </div>
</header>

<!-- Category Filter -->
<section class="max-w-7xl mx-auto px-8 mb-12">
  <div class="flex flex-wrap items-center gap-3">
    <button class="px-5 py-2 rounded-lg bg-primary text-on-primary font-medium text-sm transition-all">All Articles</button>
    {% for category in site.categories %}
      <a href="/categories/{{ category | slugify }}/" class="px-5 py-2 rounded-lg bg-surface-container-high text-on-surface-variant font-medium text-sm hover:bg-surface-container-highest transition-all">
        {{ category }}
      </a>
    {% endfor %}
  </div>
</section>

<!-- Blog Grid -->
<section class="max-w-7xl mx-auto px-8">
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    
    {% set posts = collections.posts | reverse %}
    {% set featuredPost = posts | first %}
    
    {% if featuredPost %}
      <!-- Featured Large Card (Asymmetry) -->
      <article class="md:col-span-2 group relative overflow-hidden rounded-xl bg-surface-container-lowest shadow-sm transition-all duration-300 hover:-translate-y-1">
        <div class="grid grid-cols-1 lg:grid-cols-2">
          <div class="h-64 lg:h-full overflow-hidden">
            <a href="{{ featuredPost.url }}">
              {% image "https://lh3.googleusercontent.com/aida-public/AB6AXuCJ4MCPanoqLqOiMqS9TFOJUTKG3QFo9yIPYeild-O04be7Ku3PJ-il5aqpXDb53kNzssSZBDLy5Aa_SOCYY8VLW8tP5uxVJULdN9CrjGIlAs-HvqPznanADLKgX4np9eUvtqybw_uJVbpnWbIS_2usTNedEgJyg50HVlP-gBjiit82MZcBwSW4iVMFGYn7U-P6TO4wr4NyX9H8HnAx9rpoCSFl8YxTOXreZCkgamq4LF2nNiBRr9u7CpL78TWl7IRDXLZNo9iY7z4", featuredPost.data.title or "Featured Post", "w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" %}
            </a>
          </div>
          <div class="p-8 md:p-12 flex flex-col justify-center">
            <div class="flex items-center gap-2 mb-4">
              <span class="bg-tertiary-fixed text-on-tertiary-fixed-variant px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">Editor's Choice</span>
              <span class="text-xs text-on-surface-variant font-medium">10 Min Read</span>
            </div>
            <h2 class="text-3xl font-bold tracking-tight text-on-surface mb-4 group-hover:text-primary transition-colors">
              <a href="{{ featuredPost.url }}">{{ featuredPost.data.title }}</a>
            </h2>
            <p class="text-on-surface-variant mb-6 leading-relaxed">
              {{ featuredPost.data.description or featuredPost.templateContent | truncate(150) }}
            </p>
            <div class="mt-auto flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-surface-container-high overflow-hidden">
                  <img class="w-full h-full object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDjt8JIgl1HGqAmI8PV6GtESjfzrLWEznVrtWSYr7-o0EhLDlpg-A_f3IdKYbpgWFGMdQW9jy9Y7WZc8M2HQdiwTwjfuuXNOqqsVZMR9b4gy5WTAGmIdNsBTUW_DBuj1MhF1V6jV7i1UBNv9IuH8RoSfnigD5K7AWuwragTNYEzELhwHyHpzDI_QJzURi01zxJFJjqW78m-KhzhLv5R4SQ_18008HGAhjMHgXU3JS19Q9rNYcwXIrLX5BkhTiD_BedVYP5GW7SP8mg" alt="Author"/>
                </div>
                <div>
                  <p class="text-sm font-bold text-on-surface">{{ featuredPost.data.author or site.author }}</p>
                  <p class="text-xs text-on-surface-variant">Chief Editor</p>
                </div>
              </div>
              <a href="{{ featuredPost.url }}" class="material-symbols-outlined text-primary group-hover:translate-x-1 transition-transform">arrow_forward</a>
            </div>
          </div>
        </div>
      </article>
    {% endif %}

    <!-- Standard Cards -->
    {% for post in posts | slice(1) %}
      <article class="group flex flex-col bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden transition-all duration-300 hover:-translate-y-1">
        <div class="h-56 overflow-hidden">
          <a href="{{ post.url }}">
            {% image "https://lh3.googleusercontent.com/aida-public/AB6AXuAmKxeIGAHwiHfsV5tihkuhwFh80lOFB5SPuWnMaoCJPTeaMZ6jXinGR5ihl_neEmlAaj3GXGr6ohRtntwfol6Sr105-2NiKY_uB8afRRre_K19Ht8GxAn3A3IT7t0mCe0huyMlZqZ-LNspvoATrNou-8IbMNhr_IOsAlC6Fa48Z1qgN6KNrbmsumVycPY5S_FVB47DM1ANOlctr0Z305Aonb-W3bM26A7MJVQfrwPbDQSP6mh0OT1dOljrZS6dbsjS3TnxHm8pZ6k", post.data.title or "Blog Post", "w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" %}
          </a>
        </div>
        <div class="p-6 flex flex-col flex-grow">
          <span class="text-[10px] font-bold uppercase tracking-wider text-primary mb-2">Analysis</span>
          <h3 class="text-xl font-bold tracking-tight text-on-surface mb-3 group-hover:text-primary transition-colors">
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h3>
          <p class="text-sm text-on-surface-variant mb-6 line-clamp-3">
            {{ post.data.description or post.templateContent | truncate(120) }}
          </p>
          <div class="mt-auto pt-4 border-t border-surface-container-high flex items-center justify-between">
            <span class="text-xs font-medium text-on-surface-variant">{{ post.date | date("MMM D, YYYY") }}</span>
            <a href="{{ post.url }}" class="material-symbols-outlined text-primary group-hover:translate-x-1 transition-transform">east</a>
          </div>
        </div>
      </article>
    {% endfor %}

  </div>

  <!-- Load More Section -->
  <div class="mt-20 flex flex-col items-center">
    <button class="px-10 py-4 bg-surface-container-high text-primary font-bold rounded-full hover:bg-surface-container-highest transition-all active:scale-95 flex items-center gap-2">
      Load more articles
      <span class="material-symbols-outlined text-lg">expand_more</span>
    </button>
    <p class="mt-4 text-xs text-on-surface-variant/60 font-medium">Showing {{ posts.length }} articles</p>
  </div>
</section>
