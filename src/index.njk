---
layout: layouts/base.njk
title: Home
---

<!-- Hero Section -->
<section class="max-w-7xl mx-auto px-8 py-20 lg:py-32 flex flex-col md:flex-row items-center gap-16">
    <div class="flex-1 space-y-8">
      <div class="inline-flex items-center bg-tertiary-fixed text-on-tertiary-fixed-variant px-4 py-1 rounded-sm text-[0.7rem] font-bold uppercase tracking-widest">
        The Solo Founder's Edge
      </div>
      <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight text-primary leading-tight font-headline">
        Discover the best AI tools to run your <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-blue-500">solo business</span>
      </h1>
      <p class="text-xl text-on-surface-variant leading-relaxed max-w-xl font-body">
        {{ site.description }}
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/quiz/" class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-10 py-5 rounded-full font-bold text-lg hover:shadow-2xl hover:translate-y-[-2px] transition-all flex items-center group">
          Diagnostic: Find Your AI Stack
          <span class="material-symbols-outlined ml-2 group-hover:ml-4 transition-all">bolt</span>
        </a>
        <a href="/resources/" class="bg-transparent border-2 border-outline-variant/30 text-primary px-10 py-5 rounded-full font-bold text-lg hover:bg-surface-container-low transition-all">
          Explore The Engine
        </a>
      </div>
    </div>
    <div class="flex-1 relative">
      <div class="aspect-square bg-surface-container-high rounded-xl overflow-hidden shadow-2xl relative transform rotate-3">
        {% image "https://lh3.googleusercontent.com/aida-public/AB6AXuDtxrN_Am05WBKECV0memTxI1GVRm6pKB-eULdh1A7EDnu0pWc5igOm0IXue0EsXkkL-TtROi_Pw2Fof3poucHwHlht74--zeMSN_wEikvMElRGZ_lm-zL1S016sf3ubl4LNhF689cA14HfHxyuEnxL7Ci3wGtt5F0Mi-bs9WTeTbAKgN4KV0QHBFt4YYDWzyZVmwCWAJ8t9NnMZFnuoXYnTnI1Doe6IG_G804kbKAbRsnSSC-JUXHlZJ4mFRVb7JaG84KDdKzgWDg", "AI Visualization", "w-full h-full object-cover grayscale mix-blend-multiply opacity-80" %}
        <div class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent"></div>
      </div>
      <div class="absolute -bottom-6 -left-6 bg-surface-container-lowest p-6 rounded-xl shadow-2xl max-w-xs transform -rotate-2">
        <p class="text-sm font-bold text-primary mb-2 uppercase tracking-tighter">Featured Strategy</p>
        <p class="text-on-surface text-lg font-headline font-bold leading-tight">Automating customer support with LLMs</p>
      </div>
    </div>
  </section>

  <!-- Categories Section (Bento Inspired) -->
  <section class="bg-surface-container-low py-24">
    <div class="max-w-7xl mx-auto px-8">
      <div class="mb-16">
        <h2 class="text-3xl font-extrabold text-primary font-headline tracking-tight">Curated Categories</h2>
        <p class="text-on-surface-variant mt-2">Tools grouped by business function.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        {% for category in site.categories %}
          {% if loop.index == 1 %}
            <div class="md:col-span-2 bg-surface-container-lowest p-8 rounded-xl shadow-sm hover:shadow-md transition-all flex flex-col justify-between group border-l-4 border-primary">
              <div>
                <span class="material-symbols-outlined text-4xl text-primary mb-4">edit_note</span>
                <h3 class="text-2xl font-bold mb-2">{{ category }}</h3>
                <p class="text-on-surface-variant">Content creation, copywriting, and editorial automation.</p>
              </div>
              <a class="mt-6 inline-flex items-center text-primary font-bold group-hover:gap-2 transition-all" href="/categories/{{ category | slugify }}/">
                Browse Tools <span class="material-symbols-outlined text-sm ml-1">arrow_forward</span>
              </a>
            </div>
          {% elif loop.index == 4 %}
             <div class="md:col-span-4 bg-primary text-on-primary p-8 rounded-xl flex items-center justify-between overflow-hidden relative">
              <div class="z-10">
                <h3 class="text-2xl font-bold mb-2">{{ category }}</h3>
                <p class="text-primary-container max-w-md">Master your schedule and focus with AI-augmented calendar and task management.</p>
                <a href="/categories/{{ category | slugify }}/" class="mt-6 inline-block bg-surface-container-lowest text-primary px-6 py-2 rounded-full font-bold">Explore</a>
              </div>
              <span class="material-symbols-outlined text-[10rem] opacity-10 absolute -right-4 -bottom-4 rotate-12">bolt</span>
            </div>
          {% else %}
            <div class="bg-surface-container-lowest p-8 rounded-xl shadow-sm hover:shadow-md transition-all group">
              <span class="material-symbols-outlined text-4xl {% if loop.index == 2 %}text-blue-500{% else %}text-tertiary-container{% endif %} mb-4">{% if loop.index == 2 %}campaign{% else %}settings_suggest{% endif %}</span>
              <h3 class="text-xl font-bold mb-2">{{ category }}</h3>
              <p class="text-sm text-on-surface-variant">Acquisition, social media, and SEO enhancement.</p>
              <a class="mt-4 block text-primary font-bold text-sm" href="/categories/{{ category | slugify }}/">View all</a>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Featured Posts (Asymmetric Layout) -->
  {% set latestPost = collections.posts | reverse | first %}
  {% if latestPost %}
  <section class="py-24 max-w-7xl mx-auto px-8">
    <div class="flex flex-col md:flex-row gap-12 items-end mb-16">
      <h2 class="text-4xl font-extrabold text-primary font-headline flex-1 tracking-tighter">The Editorial Choice</h2>
      <div class="h-[2px] bg-outline-variant/20 flex-1 hidden md:block mb-4"></div>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <!-- Large Featured Card -->
      <div class="lg:col-span-8 group">
        <a href="{{ latestPost.url }}" class="block">
          <div class="aspect-[16/9] bg-surface-container overflow-hidden rounded-xl mb-6 shadow-sm">
            {% image "https://lh3.googleusercontent.com/aida-public/AB6AXuDmfAzKRec3BkauJYgXfSqvGhXgtKat5i6M-Q86D4nHunaj_8CTWEkL2PwbVJGub2wAyHlhpltfLzZ6Q4UrLzLe_GLMfmE8mpGz-fIJ3Wm0H50r11JbvSiPIbQ03QmTs9L_XhVbupG9ctLz65uZOCPyus0dhf0bKGt-KvQ05SXcK8yjwtkGyArrUqkdzLoWeye6wcoK8X7uGgKSdxxL4A6V55_0lRN2v4BWRUhMmyfB2l_nQObBGJozj3taIXJyuJJLGTzQ2baL3RI", latestPost.data.title, "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %}
          </div>
        </a>
        <span class="text-tertiary-container font-bold text-xs uppercase tracking-widest">Featured Report</span>
        <h3 class="text-3xl font-bold mt-2 mb-4 leading-tight group-hover:text-blue-700 transition-colors">
          <a href="{{ latestPost.url }}">{{ latestPost.data.title }}</a>
        </h3>
        <p class="text-on-surface-variant text-lg leading-relaxed mb-6">
          {{ latestPost.data.description or latestPost.templateContent | truncate(200) }}
        </p>
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 rounded-full bg-surface-container-highest overflow-hidden">
            <img alt="Author" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAiy5ID7KQPAjMsIEwiPJTt2scpoBNz9HJ1B3fCV9oLYVAMEf0vZ0DbQ3b-hjGU3GLPnSyHoqwI2tHm2Evxog9JaDYcRWBltD1tC6b6KX69pRp9THEld_d9M7HL_ZWZBSvrrW-RfzM1-y2e9FheFrh8gh12xIzqhRwmf0lD3mrm1rK0heGP_fIKHFzq5cw8EYUwKTIRFpjR4Ff6hrIf1mCnaYfgep97Fe5IiKz76EOeaDaUSbgmfG-yY9dgnZeONI8GcqpVnlT1WZU"/>
          </div>
          <span class="font-bold text-on-surface">{{ latestPost.data.author or site.author }}</span>
          <span class="text-outline text-sm">• {{ latestPost.date | date("MMM D, YYYY") }}</span>
        </div>
      </div>
      <!-- Side Sidebar Content -->
      <div class="lg:col-span-4 space-y-12">
        {% for post in collections.posts | reverse | slice(1, 3) | first %}
          <div class="group border-b border-outline-variant/20 pb-8">
            <span class="text-blue-600 font-bold text-xs uppercase tracking-widest">Trend Analysis</span>
            <h4 class="text-xl font-bold mt-2 leading-tight group-hover:text-blue-700 transition-colors">
              <a href="{{ post.url }}">{{ post.data.title }}</a>
            </h4>
            <p class="text-on-surface-variant text-sm mt-2 line-clamp-2">{{ post.data.description }}</p>
          </div>
        {% endfor %}
        <div class="bg-surface-container-high p-8 rounded-xl">
          <h4 class="font-headline font-extrabold text-primary text-xl mb-4">Trending Tags</h4>
          <div class="flex flex-wrap gap-2">
            {% for category in site.categories %}
              <span class="bg-surface-container-lowest px-3 py-1 rounded-sm text-xs font-bold text-on-surface-variant uppercase">{{ category }}</span>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </section>
  {% endif %}

  <!-- Latest Posts Grid -->
  <section class="py-24 bg-surface">
    <div class="max-w-7xl mx-auto px-8">
      <div class="flex justify-between items-end mb-12">
        <h2 class="text-3xl font-extrabold text-primary font-headline tracking-tight">Latest Analysis</h2>
        <a class="text-primary font-bold hover:underline underline-offset-8 decoration-primary/30" href="/blog/">View all posts</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {% for post in collections.posts | reverse | slice(0, 3) %}
          <div class="bg-surface-container-lowest rounded-xl shadow-sm overflow-hidden group hover:shadow-xl transition-all duration-300">
            <a href="{{ post.url }}">
              <div class="h-48 bg-surface-container overflow-hidden">
                {% image "https://lh3.googleusercontent.com/aida-public/AB6AXuABNqsOiILCETWs2HUnsrwF1c3lgdf1LeSAiX1H8hCVhJ3eKZZwM0t259bqghIaWdtV6JvDQBz5uvAjvP1cttz0bLVEuyi_R3_GIBbmaxeFwN9riEJlC1bMtLJGL-eCobWydd3IR7ON3NulfjmsSjTJu-0HnRFD9_tf4fAV9rCQ0sIvSAcsaT4aVMik2zBwQjATYuIujlO6di6B8_Rp8FONG0-LxBijOO0nB-24gLQTwEV-mIsPcn0r4WKAcAFH95GhhkR3MGzH1j8", post.data.title, "w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" %}
              </div>
            </a>
            <div class="p-6">
              <div class="flex gap-2 mb-3">
                <span class="text-[0.65rem] font-bold px-2 py-0.5 bg-surface-container-highest rounded-sm uppercase tracking-wider text-outline">Analysis</span>
              </div>
              <h3 class="font-bold text-xl mb-3 leading-snug group-hover:text-blue-700 transition-colors">
                <a href="{{ post.url }}">{{ post.data.title }}</a>
              </h3>
              <p class="text-on-surface-variant text-sm line-clamp-3">{{ post.data.description }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <!-- Newsletter Signup Section -->
  <section class="max-w-7xl mx-auto px-8 mb-24">
    <div class="bg-gradient-to-br from-primary to-primary-container rounded-2xl p-12 md:p-20 relative overflow-hidden flex flex-col md:flex-row items-center gap-12">
      <!-- Background Pattern -->
      <div class="absolute inset-0 opacity-10 pointer-events-none">
        <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_1px_1px,_rgba(255,255,255,0.15)_1px,_transparent_0)] bg-[length:40px_40px]"></div>
      </div>
      <div class="flex-1 relative z-10 text-center md:text-left">
        <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-6 font-headline tracking-tight">The Weekly Curator</h2>
        <p class="text-on-primary-container text-lg max-w-lg mb-8">Get the 5-minute digest on the AI tools that actually matter for solo founders. Includes our 15-page "AI Business Automator" PDF guide for free.</p>
        <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto md:mx-0 relative z-10" name="newsletter-home" method="POST" data-netlify="true" action="/success/">
          <input type="hidden" name="form-name" value="newsletter-home" />
          <div class="hidden"><label>Don't fill this out if you're human: <input name="bot-field" /></label></div>
          <input class="flex-grow rounded-full px-6 py-4 bg-white/10 border border-white/20 text-white placeholder:text-white/60 focus:bg-white/20 focus:outline-none transition-all font-body" placeholder="Your work email" type="email" name="email" required/>
          <button class="bg-surface-container-lowest text-primary font-bold px-8 py-4 rounded-full hover:shadow-xl hover:scale-105 transition-all" type="submit">Join Founders</button>
        </form>
        <p class="text-white/40 text-[0.7rem] mt-4 uppercase tracking-widest font-bold">Zero spam. Pure strategy. Unsubscribe anytime.</p>
      </div>
      <div class="flex-1 relative z-10 hidden lg:block">
        <div class="bg-white/10 backdrop-blur-md rounded-xl p-6 border border-white/20 rotate-6 shadow-2xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-full bg-on-tertiary-container flex items-center justify-center">
              <span class="material-symbols-outlined text-sm text-white">auto_awesome</span>
            </div>
            <span class="text-white font-bold text-sm">FREE LEAD MAGNET</span>
          </div>
          <p class="text-white font-headline text-2xl font-extrabold leading-tight">The AI Business Automator</p>
          <p class="text-white/60 text-sm mt-2">15 workflows that saved 100+ hours monthly.</p>
          <div class="mt-6 h-1 w-full bg-white/10 rounded-full overflow-hidden">
            <div class="h-full bg-on-tertiary-container w-3/4"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

